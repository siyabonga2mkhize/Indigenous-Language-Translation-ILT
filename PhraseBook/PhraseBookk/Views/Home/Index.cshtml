@{
    ViewData["Title"] = "Home Page";
    var phraseOfTheDay = ViewBag.PhraseOfTheDay as PhraseBookk.Models.Phrase;
}

<div class="container mt-4">

    <!-- Welcome & Hero -->
    <div class="text-center">
        <h1 class="display-4">Welcome to PhraseBook</h1>
        <p class="lead text-muted">Your campus phrasebook for all 11 official South African languages.</p>
    </div>

    <!-- Quick Search -->
    <div class="row justify-content-center mt-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>🔍 Quick Search</h5>
                    <form asp-controller="Phrases" asp-action="Index" method="get">
                        <div class="input-group">
                            <input type="text" name="keyword" class="form-control" placeholder="Search for a phrase..." />
                            <button type="submit" class="btn btn-primary">Search</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Category Cards -->
    <div class="row mt-4">
        <div class="col-12">
            <h5>📂 Browse by Category</h5>
            <div class="row g-2">
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <div class="col-md-2 col-4">
                            <a asp-controller="Phrases" asp-action="Index" asp-route-categoryId="@cat.Id" class="text-decoration-none">
                                <div class="card h-100 text-center p-2 shadow-sm">
                                    <div class="card-body">
                                        <span style="font-size: 2rem;">📁</span>
                                        <p class="small fw-bold mt-1 mb-0">@cat.Name</p>
                                        @if (!string.IsNullOrEmpty(cat.Latitude))
                                        {
                                            <small class="text-muted">📍</small>
                                        }
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Phrase of the Day -->
    <div class="row justify-content-center mt-4">
        <div class="col-md-8">
            <div class="card border-warning shadow-lg">
                <div class="card-header bg-warning text-dark">
                    <strong>🌟 Phrase of the Day</strong>
                    <span class="float-end text-muted small">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
                </div>
                <div class="card-body text-start">
                    @if (phraseOfTheDay != null)
                    {
                        <h3 class="card-title">@phraseOfTheDay.EnglishText</h3>
                        <p class="text-muted">
                            <span class="badge bg-info">@phraseOfTheDay.Category?.Name</span>
                        </p>
                        <hr />
                        <h6>Translations:</h6>
                        @if (phraseOfTheDay.Translations != null && phraseOfTheDay.Translations.Any(t => t.Status == PhraseBookk.Models.ContentStatus.Approved))
                        {
                            <ul class="list-unstyled">
                                @foreach (var trans in phraseOfTheDay.Translations.Where(t => t.Status == PhraseBookk.Models.ContentStatus.Approved))
                                {
                                    <li>
                                        <span class="badge bg-secondary">@trans.Language.ToString()</span>
                                        @trans.TranslatedText
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted">No approved translations yet.</p>
                        }
                        <div class="mt-3">
                            <a asp-controller="Phrases" asp-action="Details" asp-route-id="@phraseOfTheDay.Id" class="btn btn-outline-primary">
                                View Full Phrase →
                            </a>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Phrases" asp-action="SubmitTranslation" asp-route-id="@phraseOfTheDay.Id" class="btn btn-outline-success ms-2">
                                    ✍️ Suggest
                                </a>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary ms-2">
                                    🔑 Login to Suggest
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No phrases available. Please check back later.</p>
                    }
                </div>
                <div class="card-footer text-muted small">
                    Phrase of the Day updates daily. Check back tomorrow for a new phrase!
                </div>
            </div>
        </div>
    </div>

    <!-- Features -->
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div style="font-size: 3rem;">🔍</div>
                    <h5>Search Phrases</h5>
                    <p class="text-muted">Search across 11 languages with highlighting.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div style="font-size: 3rem;">✍️</div>
                    <h5>Suggest Translations</h5>
                    <p class="text-muted">Help others by submitting translations.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <div style="font-size: 3rem;">⭐</div>
                    <h5>Save Favourites</h5>
                    <p class="text-muted">Save phrases you use often.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Quick Stats -->
    @if (User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
    {
        <div class="row mt-4">
            <div class="col-md-12">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        <strong>📊 Admin Quick Stats</strong>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3">
                                <h4>@ViewBag.PendingCount</h4>
                                <p class="text-muted">Pending Translations</p>
                            </div>
                            <div class="col-md-3">
                                <h4>@ViewBag.TotalPhrases</h4>
                                <p class="text-muted">Total Phrases</p>
                            </div>
                            <div class="col-md-3">
                                <h4>@ViewBag.TotalTranslations</h4>
                                <p class="text-muted">Total Translations</p>
                            </div>
                            <div class="col-md-3">
                                <a asp-controller="PhrasesAdmin" asp-action="Index" class="btn btn-primary">
                                    Go to Dashboard →
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</div>