@model IEnumerable<PhraseBookk.Models.Translation>
@{
    ViewData["Title"] = "My Translation Submissions";
    var totalCount = ViewBag.TotalCount ?? 0;
    var pendingCount = ViewBag.PendingCount ?? 0;
    var approvedCount = ViewBag.ApprovedCount ?? 0;
    var rejectedCount = ViewBag.RejectedCount ?? 0;
    var currentFilter = ViewBag.CurrentFilter as string;
}

<div class="container mt-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>📝 My Translation Submissions</h1>
            <p class="text-muted">Track the status of your translation suggestions.</p>
        </div>
        <div>
            <span class="badge bg-primary fs-6 p-2">Total: @totalCount</span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Buttons -->
    <div class="btn-group mb-4 flex-wrap" role="group">
        <a asp-action="MySubmissions" asp-route-statusFilter="" class="btn @(string.IsNullOrEmpty(currentFilter) ? "btn-primary" : "btn-outline-secondary")">
            All (@totalCount)
        </a>
        <a asp-action="MySubmissions" asp-route-statusFilter="Pending" class="btn @(currentFilter == "Pending" ? "btn-warning" : "btn-outline-secondary")">
            ⏳ Pending (@pendingCount)
        </a>
        <a asp-action="MySubmissions" asp-route-statusFilter="Approved" class="btn @(currentFilter == "Approved" ? "btn-success" : "btn-outline-secondary")">
            ✅ Approved (@approvedCount)
        </a>
        <a asp-action="MySubmissions" asp-route-statusFilter="Rejected" class="btn @(currentFilter == "Rejected" ? "btn-danger" : "btn-outline-secondary")">
            ❌ Rejected (@rejectedCount)
        </a>
    </div>

    <!-- Submissions List -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem;">📝</div>
            <h3 class="mt-3">No submissions yet</h3>
            <p class="text-muted">You haven't submitted any translations yet. Start by searching for a phrase and suggesting a translation.</p>
            <a asp-controller="Phrases" asp-action="Index" class="btn btn-primary mt-3">
                🔍 Search for Phrases
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100 shadow-sm hover-lift">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h6 class="card-title">@item.Phrase?.EnglishText</h6>
                                @switch (item.Status)
                                {
                                    case PhraseBookk.Models.ContentStatus.Approved:
                                        <span class="badge bg-success">✅ Approved</span>
                                        break;
                                    case PhraseBookk.Models.ContentStatus.Pending:
                                        <span class="badge bg-warning text-dark">⏳ Pending</span>
                                        break;
                                    case PhraseBookk.Models.ContentStatus.Rejected:
                                        <span class="badge bg-danger">❌ Rejected</span>
                                        break;
                                }
                            </div>
                            <p class="text-muted small">
                                <span class="badge bg-info">@item.Language.ToString()</span>
                                <span class="badge bg-secondary">@item.Phrase?.Category?.Name</span>
                            </p>
                            <p class="card-text">
                                <strong>Translation:</strong> @item.TranslatedText
                            </p>
                            @if (item.Status == PhraseBookk.Models.ContentStatus.Rejected && !string.IsNullOrEmpty(item.AdminReviewComment))
                            {
                                <div class="alert alert-danger alert-sm p-2 mt-2">
                                    <small><strong>Reason:</strong> @item.AdminReviewComment</small>
                                </div>
                            }
                            <p class="card-text small text-muted">
                                Submitted: @item.CreatedDate.ToString("dd MMM yyyy HH:mm")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-controller="Phrases" asp-action="Details" asp-route-id="@item.PhraseId" class="btn btn-sm btn-outline-primary w-100">
                                View Phrase →
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Back to Search -->
    <div class="mt-4">
        <a asp-controller="Phrases" asp-action="Index" class="btn btn-secondary">
            🔍 Back to Search
        </a>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important;
        }

    .alert-sm {
        padding: 0.25rem 0.5rem;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
    }
</style>
