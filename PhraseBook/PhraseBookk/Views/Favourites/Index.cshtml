@model IEnumerable<PhraseBookk.Models.Favorite>
@{
    ViewData["Title"] = "My Favourites";
    var totalFavourites = Model.Count();
}

<div class="container mt-4">
    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>⭐ My Favourites</h1>
            <p class="text-muted">Your saved phrases for quick reference.</p>
        </div>
        <div>
            <span class="badge bg-primary fs-6 p-2">❤️ @totalFavourites phrases</span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem;">❤️</div>
            <h3 class="mt-3">No favourites yet</h3>
            <p class="text-muted">Start saving phrases you use often by clicking the ❤️ icon on any phrase details page.</p>
            <a asp-controller="Phrases" asp-action="Index" class="btn btn-primary mt-3">
                🔍 Search for Phrases
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var favorite in Model)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100 shadow-sm hover-lift">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">@favorite.Phrase?.EnglishText</h5>
                                <form asp-controller="Favourites" asp-action="Remove" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@favorite.Id" />
                                    <button type="submit" class="btn btn-link text-danger p-0" title="Remove from favourites"
                                            onclick="return confirm('Remove this phrase from your favourites?')">
                                        <span style="font-size: 1.5rem;">❤️</span>
                                    </button>
                                </form>
                            </div>
                            <p class="text-muted small">
                                <span class="badge bg-info">@favorite.Phrase?.Category?.Name</span>
                            </p>
                            <p class="card-text small text-muted">
                                Saved: @favorite.SavedDate.ToString("dd MMM yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-controller="Phrases" asp-action="Details" asp-route-id="@favorite.PhraseId" class="btn btn-sm btn-outline-primary w-100">
                                View Full Phrase →
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Back to Search -->
    <div class="mt-4">
        <a asp-controller="Phrases" asp-action="Index" class="btn btn-secondary">
            🔍 Back to Search
        </a>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important;
        }
</style>