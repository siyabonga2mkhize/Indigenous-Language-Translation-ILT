@model IEnumerable<InnoDevsITL.Models.Faculty>

@{
    ViewData["Title"] = "Faculties";
}

<h2>Faculties</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add New Faculty</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var faculty in Model)
        {
            <tr>
                <td>@faculty.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@faculty.Id" class="btn btn-sm btn-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@faculty.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
